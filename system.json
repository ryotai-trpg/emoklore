  "version": "0.0.2",
  "compatibility": {
    "minimum": 13,
    "verified": 13
  },
  "authors": [{
    "name": "Ryotai",
    "discord": "@ryotai."
  }],
  "esmodules": ["emoklore.mjs"],
  "styles": ["emoklore.css"],
  "languages": [
    {
      "lang": "ja",
      "name": "日本語",
      "path": "lang/ja.json"
