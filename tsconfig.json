{
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "rootDir": "./",
    "outDir": "dist",
    "noEmit": true,

    "strict": false,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitAny": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["fvtt-types"]
  },
  "include": ["*.ts", "module/**/*"],
  "exclude": ["node_modules", "dist"]
}
