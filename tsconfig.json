{
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "rootDir": "./",
    "outDir": "dist",
    "noEmit": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["fvtt-types"]
  },
  "include": ["module/**/*"],
  "exclude": ["node_modules", "dist"]
}
