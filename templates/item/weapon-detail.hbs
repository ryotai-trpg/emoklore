{{! Weapon Detail Tab }}
<section class='tab detail {{tab.cssClass}}' data-group='primary' data-tab='detail'>
  <div class="weapon-details">
    {{#if isPlay}}
    <div class="form-group">
      <label>{{localize "EMOKLORE.Item.rangeType.label"}}</label>
      <span class="value">{{localize (concat "EMOKLORE.Item.rangeType." system.rangeType)}}</span>
    </div>

    <div class="form-group">
      <label>{{localize "EMOKLORE.Item.attackPower"}}</label>
      <span class="value">{{system.attackPower}}</span>
    </div>

    <div class="form-group">
      <label>{{localize "EMOKLORE.Item.range.label"}}</label>
      <span class="value">
        {{#if (eq system.rangeType "melee")}}
          {{localize "EMOKLORE.Item.range.melee"}}
        {{else}}
          {{system.range}}m
        {{/if}}
      </span>
    </div>

    {{#if system.notes}}
    <div class="form-group">
      <label>{{localize "EMOKLORE.Item.notes"}}</label>
      <div class="value notes">{{{system.notes}}}</div>
    </div>
    {{/if}}

    {{else}}
    <div class="form-group">
      {{formGroup systemFields.rangeType value=system.rangeType}}
    </div>

    <div class="form-group">
      {{formGroup systemFields.attackPower value=system.attackPower}}
    </div>

    <div class="form-group" data-range-type="{{system.rangeType}}">
      {{#if (eq system.rangeType "ranged")}}
      {{formGroup systemFields.range value=system.range}}
      {{else}}
      <label>{{localize "EMOKLORE.Item.range.label"}}</label>
      <span class="value">{{localize "EMOKLORE.Item.range.melee"}}</span>
      {{/if}}
    </div>

    <div class="form-group">
      {{formGroup systemFields.notes value=system.notes}}
    </div>
    {{/if}}
  </div>
</section>

