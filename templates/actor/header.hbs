{{! Sheet Header }}
<div>
  <header class="sheet-header">
    <div class="container">
      <div class="name">
        {{#if isPlay}}
        {{source.name}}
        {{else}}
        {{formInput fields.name value=source.name placeholder=(localize "DOCUMENT.FIELDS.name.label")
        aria=(object label=(localize "DOCUMENT.FIELDS.name.label"))}}
        {{/if}}
      </div>

      <div class="resources">
        {{#if isPlay}}
        <div class="hp bar">
          <label for="character-hp">HP</label>
          <span class="value">
            {{ system.resources.hp.value }}/{{ system.resources.hp.max }}
          </span>
          <button>
            <i class="fa-duotone fa-solid fa-minus"></i>
          </button>
          <progress 
            id="character-hp"
            value="{{ system.resources.hp.value }}" 
            max="{{ system.resources.hp.max }}"
          ></progress>
          <button>
            <i class="fa-duotone fa-solid fa-plus"></i>
          </button>
        </div>
        <div class="mp bar">
          <label for="character-mp">MP</label>
          <button>
            <i class="fa-duotone fa-solid fa-minus"></i>
          </button>
          <progress 
            id="character-mp"
            value="{{ system.resources.mp.value }}" 
            max="{{ system.resources.mp.max }}"
            ></progress>
          <button>
            <i class="fa-duotone fa-solid fa-plus"></i>
          </button>
        </div>
        <div class="sympathy bar">
          <label for="character-sympathy">∞共鳴</label>
          <button>
            <i class="fa-duotone fa-solid fa-minus"></i>
          </button>
          <progress 
            id="character-sympathy"
            value="3" 
            max="9"
            ></progress>
          <button>
            <i class="fa-duotone fa-solid fa-plus"></i>
          </button>
        </div>
        {{else}}
        <div class="hp">
          最大HP: {{ system.resources.hp.max }}
        </div>
        <div class="mp">
          最大MP: {{ system.resources.mp.max }}
        </div>
        {{/if}}
      </div>

  </header>
    </div>
