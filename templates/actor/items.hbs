{{! Items Tab }}
<section
  class='tab items {{tab.cssClass}}'
  data-group='primary'
  data-tab='items'
>
  <ol class='items-list'>
    <li class='items-header'>
      <div class='item-name'>
        {{localize 'TYPES.Item.weapon'}}
      </div>
      <div class='item-range-type'>
        {{localize 'EMOKLORE.Item.rangeType.label'}}
      </div>
      <div class='item-attack-power'>
        {{localize 'EMOKLORE.Item.attackPower'}}
      </div>
      <div class='item-range'>
        {{localize 'EMOKLORE.Item.range.label'}}
      </div>
      <div class='item-controls'>
        {{#if editable}}
        <a
          class='item-control'
          data-action='createDoc'
          data-document-class='Item'
          data-type='weapon'
          data-tooltip='{{localize "DOCUMENT.Create" type=(localize "TYPES.Item.weapon")}}'
        >
          <i class='fas fa-plus'></i>
        </a>
        {{/if}}
      </div>
    </li>

    <ol class='item-list'>
      {{#each @root.actor.itemTypes.weapon as |item|}}
        <li
          class='item draggable'
          data-item-id='{{item.id}}'
          data-document-class='Item'
        >
          <div class='item-name'>
            <img class='item-image' src='{{item.img}}' height="24" width="24"/>
            <div>{{item.name}}</div>
          </div>
          <div class='item-range-type'>{{localize (concat "EMOKLORE.Item.rangeType." item.system.rangeType)}}</div>
          <div class='item-attack-power'>{{item.system.attackPower}}</div>
          <div class='item-range'>{{#if (eq item.system.rangeType "melee")}}{{localize "EMOKLORE.Item.range.melee"}}{{else}}{{item.system.range}}m{{/if}}</div>
          <div class='item-controls'>
            {{#if @root.editable}}
            <a
              class='item-control'
              data-action='viewDoc'
              data-tooltip='{{localize "DOCUMENT.Update" type=(localize "TYPES.Item.weapon")}}'
            >
              <i class='fas fa-edit'></i>
            </a>
            <a
              class='item-control'
              data-action='deleteDoc'
              data-tooltip='{{localize "DOCUMENT.Delete" type=(localize "TYPES.Item.weapon")}}'
            >
              <i class='fas fa-trash'></i>
            </a>
            {{/if}}
          </div>
        </li>
      {{/each}}
    </ol>
  </ol>
</section>

