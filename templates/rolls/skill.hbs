<div class="dice-roll" data-action="expandRoll">
    {{#if flavor}}
    <div class="dice-flavor">{{flavor}}</div>
    {{/if}}
      <h3>{{localize "EMOKLORE.skillRoll" skillName=skillName}}</h3>
      <div class="container">
        <div class="level">レベル：{{level}}</div>
        {{#if bonus}}
        <div class="bonus">ダイスボーナス：{{bonus}}</div>
        {{/if}}
        <div class="target">
          判定値：{{baseTarget}}{{#if targetModifier}}{{targetModifier}} {{/if}}
        </div>
        {{#if successModifier}}
        <div class="sccess">
          成功数修正：{{successModifier}}
        </div>
        {{/if}}
      </div>
      {{#if successModifier}}
      {{successModifier}}
      {{/if}}
    <div class="dice-result">
      <div class="dice-formula">成功数：{{result}}</div>
        {{{tooltip}}}
        <h4 class="dice-total">{{localize (concat "EMOKLORE.result." resultName)}}</h4>
    </div>
</div>
